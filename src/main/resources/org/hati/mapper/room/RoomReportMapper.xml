<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.hati.room.mapper.RoomReportMapper">

    <!-- 신고 접수 INSERT -->
    <!-- report_id는 trg_reports_bi 트리거로 seq_reports.NEXTVAL 자동 부여 -->
    <!-- status DEFAULT 0 (PENDING), created_at DEFAULT sysdate -->
    <insert id="insertReport" parameterType="map">
        INSERT INTO reports (
            reporter_account_id,
            target_account_id,
            target_type,
            target_id,
            content
        ) VALUES (
            #{reporterAccountId},
            #{targetAccountId},
            #{targetType},
            #{targetId},
            #{content}
        )
    </insert>

</mapper>
